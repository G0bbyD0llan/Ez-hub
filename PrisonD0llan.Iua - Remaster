			}, function()
				MainMenu.Visible = false
			end)
			MinimizeButton.Text = "+"
			FastTween(MinimizeButton, 0.25, {
				BackgroundColor3 = Color3.new(0.25098, 0.831373, 0),
				TextColor3 = Color3.new(0.0156863, 1, 0)
			})
		end
	end)
	
	CloseButton.Activated:Once(function()
