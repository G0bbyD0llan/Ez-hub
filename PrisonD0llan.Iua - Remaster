	local Full = Transition.Full
	local LeftBorder = Transition["Left-Border"]
	local RightBorder = Transition["Right-Border"]
	
	--// Reset transition visuals
	local function resetTransition()
		Transition.Visible = false
		Full.Visible = false
		LeftBorder.Visible = false
		RightBorder.Visible = false
	end
	
	resetTransition()
	
	--// Page visibility handler
	local function showPage(page)
		for _, p in pairs(Pages) do
			p.frame.Visible = false
		end
		page.frame.Visible = true
	end
	
	showPage(ActualPage)
	
	--// Transition logic
	local function MakeTransition(currentPage, targetPage)
		if currentPage == targetPage then return end
	
		local currentIndex = LocalizedPages[currentPage.name]
		local targetIndex = LocalizedPages[targetPage.name]
		local forward = targetIndex > currentIndex
	
