	local SilentAimWallCheck = true -- true / false
	
	-- AIMBOT CONFIG
	local AimBotRightClick = false -- true / false
	
	local FullCredibilityDescription = ""
	
	
	
	local function ConvertToToggle(TextButton: TextButton, OnActive: () -> nil, OnDeactive: () -> nil, TrueState: string, FalseState: string, TextContent: string)
		local IsActive = false
		local function Activate()
			IsActive = true
			OnActive()
			TextButton.Text = TextContent..TrueState
		end
		local function Deactivate()
			IsActive = false
			OnDeactive()
			TextButton.Text = TextContent..FalseState
		end
		TextButton.MouseButton1Click:Connect(function()
			if IsActive then
				Deactivate()
			else
				Activate()
			end
		end)
	end
	
	local function ChangeCredibility(HowItIs: string, ColorState: Color3)
		local Credibility = script.Parent.Credibility
		Credibility.Text = "credibility of other players of your aim: "..HowItIs
		local Tween = game:GetService("TweenService"):Create(Credibility, TweenInfo.new(0.5), {TextColor3 = ColorState})
		Tween:Play()
	end
	
	local function UpdateCredibility()
		local descriptionParts = {}
		local credibilityScore = 0
	
		-- SILENT AIM
		if SilentAimEnabled then
			table.insert(descriptionParts,
				"Silent Aim | Hit: " .. SilentAimHit ..
					" | WallCheck: " .. (SilentAimWallCheck and "ON" or "OFF")
			)
	
			credibilityScore += 2
			if SilentAimHit == "Head" then
				credibilityScore += 2
			end
			if not SilentAimWallCheck then
				credibilityScore += 1
			end
		end
	
		-- TRIGGERBOT
		if TriggerBotEnabled then
			table.insert(descriptionParts, "TriggerBot")
			credibilityScore += 3
		end
	
		-- AIMBOT
		if AimBotEnabled then
			table.insert(descriptionParts,
				"AimBot | " .. (AimBotRightClick and "Right Click" or "Always On")
			)
	
			credibilityScore += 3
			if not AimBotRightClick then
				credibilityScore += 1
			end
		end
	
		-- SAVE FULL DESCRIPTION FOR LATER USE
		FullCredibilityDescription = (#descriptionParts > 0)
			and table.concat(descriptionParts, " + ")
			or "No assistance features enabled"
	
		-- SHORT TEXT + COLOR ONLY
		if credibilityScore == 0 then
			ChangeCredibility("Very Legit", Color3.fromRGB(0, 255, 120))
		elseif credibilityScore <= 3 then
			ChangeCredibility("Mostly Legit", Color3.fromRGB(170, 255, 0))
		elseif credibilityScore <= 6 then
			ChangeCredibility("Suspicious", Color3.fromRGB(255, 170, 0))
		else
			ChangeCredibility("Very Obvious", Color3.fromRGB(255, 70, 70))
		end
	end
	
