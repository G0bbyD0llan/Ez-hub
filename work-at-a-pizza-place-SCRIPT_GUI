local function C_89()
	local script = G2L["89"];
	local Players = game:GetService("Players")
	local player = Players.LocalPlayer
	local root = player.Character:WaitForChild("HumanoidRootPart")

	local orbiting = false
	local orbitThread

	local remote
	do
		local reg = (getreg or debug.getregistry)()
		for i=1,#reg do
			local f = reg[i]
			if type(f)=="table" and rawget(f,"FireServer") and rawget(f,"BindEvents") then
				remote = f
			end
		end
	end
	function moveThing(bmd, location)
		remote:FireServer("UpdateProperty", bmd, "CFrame", location)
		wait()
		remote:FireServer("SquishDough", bmd)
	end
	-- Función que corre la órbita
	local function orbitDews(radius, speed)
		orbitThread = task.spawn(function()
			while orbiting do
				task.wait()
				local dews = workspace.AllMountainDew:GetChildren()
				local n = #dews
				if n == 0 then continue end

				local t = tick() * speed

				for i, v in ipairs(dews) do
					if v:IsA("BasePart") then
						-- Ángulo de este Dew
						local angle = (i / n) * math.pi * 2 + t

						-- Nueva posición
						local x = root.Position.X + math.cos(angle) * radius
						local z = root.Position.Z + math.sin(angle) * radius
						local y = root.Position.Y + 2 -- un poco arriba del jugador

						moveThing(v, CFrame.new(x, y, z))
					end
				end
			end
		end)
	end

	-- Función toggle
	local function toggleOrbit(radius, speed)
		orbiting = not orbiting
		if orbiting then
			print("✅ Órbita activada")
			orbitDews(radius or 10, speed or 1)
		else
			print("❌ Órbita desactivada")
		end
	end

	local oldtext = script.Parent.Text
	script.Parent.MouseButton1Click:Connect(function()
		toggleOrbit(10, 1)
		if orbiting then
			script.Parent.Text = "STOP"
		else
			script.Parent.Text = oldtext
		end
	end)
end;
