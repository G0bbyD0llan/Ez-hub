local function C_128()
	local script = G2L["128"];

	local function getTeamSpawnCFrame(teamName)
		local team = game.Teams:FindFirstChild(teamName)
		if team == nil then
			return nil
		end

		for _, instance in ipairs(workspace:GetChildren()) do
			if instance:IsA("SpawnLocation") and instance.TeamColor == team.TeamColor then
				return instance.CFrame
			end
		end

		return nil
	end


	local Names = {'Cashier',
		'Cook',
		'Pizza Boxer',
		'Delivery',
		'Supplier',
		'Manager',
	}

	local teleportPlaces = {
		["Cashier Area"] = getTeamSpawnCFrame(Names[1]),
		["Cook Area"] = getTeamSpawnCFrame(Names[2]),
		["Boxer Area"] = getTeamSpawnCFrame(Names[3]),
		["Delivery Area"] = getTeamSpawnCFrame(Names[4]),
		["Supplier Area"] = getTeamSpawnCFrame(Names[5]),
		["Manager Room"] = getTeamSpawnCFrame(Names[6])
	}

	-- 🏎️ Función para encontrar y sentarse en vehículo
	local function trySitInVehicle(humanoid: Humanoid?, folder: Folder, character: Model, oldpos: CFrame)
		if not humanoid or humanoid.Health <= 0 then return end
		local root = character:FindFirstChild("HumanoidRootPart")
		local oldPos = oldpos or (root and root.CFrame)

		-- Si ya está en un vehículo de esa carpeta, no hace nada
		if humanoid.SeatPart and folder:IsAncestorOf(humanoid.SeatPart) then
			return
		end

		humanoid.Sit = false
		task.wait(0.1)

		-- Buscar un vehículo libre
		for _, vehicle in ipairs(folder:GetChildren()) do
			if vehicle:FindFirstChild("Driver") and vehicle.Driver.Occupant == nil then
				if vehicle:FindFirstChild("Owner") and vehicle.Owner.Value ~= nil then
					continue
				end
				vehicle.Driver:Sit(humanoid)
				task.wait(0.3)
				if humanoid.SeatPart then
					break
				end
			end
		end

		-- Teleportar el vehículo a la posición original del player
		if humanoid.SeatPart and oldPos then
			local car = humanoid.SeatPart.Parent
			if car.PrimaryPart then
				car:SetPrimaryPartCFrame(oldPos)
			else
				-- fallback: usar Driver como PrimaryPart temporal
				local driver = car:FindFirstChild("Driver")
				if driver then
					car.PrimaryPart = driver
					car:SetPrimaryPartCFrame(oldPos)
				end
			end
		end
	end


	local player = game.Players.LocalPlayer

	-- Variable global para no spawnear mil veces el BodyAngularVelocity
	local currentSpinForce = nil  

	-- Función para hacer spin al auto
	local function SpinCar(carModel: Model, spinSpeed: number)
		if not carModel or not carModel.PrimaryPart then
			warn("❌ El auto no tiene PrimaryPart asignado")
			return
		end

		local seat = carModel:FindFirstChildWhichIsA("VehicleSeat", true)
		if not seat then
			warn("❌ El auto no tiene VehicleSeat")
			return
		end

		-- Verificar que el jugador esté sentado en el auto
		if seat.Occupant ~= player.Character:FindFirstChild("Humanoid") then
			warn("⚠️ No estás sentado en este auto")
			return
		end

		-- Si ya existe un spin activo, lo quitamos primero
		if currentSpinForce then
			currentSpinForce:Destroy()
			currentSpinForce = nil
		end

		-- Crear BodyAngularVelocity para girar el auto
		local bav = Instance.new("BodyAngularVelocity")
		bav.AngularVelocity = Vector3.new(0, spinSpeed, 0) -- spin en Y
		bav.MaxTorque = Vector3.new(0, math.huge, 0) -- torque infinito en Y
		bav.P = 10000
		bav.Parent = carModel.PrimaryPart

		currentSpinForce = bav
	end

	local function getcar()
		local character = game.Players.LocalPlayer.Character
		if not character then
			return nil
		end

		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if not humanoid then
			return nil
		end

		local seat = humanoid.SeatPart
		if seat and (seat:IsA("VehicleSeat") or seat:IsA("Seat")) then
			return seat.Parent
		end

		return nil
	end


	script.Parent.Activated:Connect(function()
		local player = game.Players.LocalPlayer
		local character = player.Character
		if not character then return end
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if not humanoid or humanoid.Health <= 0 then return end

		trySitInVehicle(humanoid, game.Workspace.Vehicles, character, teleportPlaces["Cook Area"]);
		local fallbacktime = false;

		local delayThread = task.delay(3, function()
			if not fallbacktime then
				fallbacktime = true;
			end
		end)

		repeat
			task.wait()
		until humanoid.SeatPart or fallbacktime

		if delayThread then
			task.cancel(delayThread)
		end

		local car = getcar()

		if car then
			SpinCar(car, 20);
		end

	end)
end;
