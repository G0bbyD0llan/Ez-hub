local function C_12b()
	local script = G2L["12b"];
	local Main = script.Parent -- TextButton
	local Parent = Main.Parent -- Frame

	local SoundSelector = Main.SoundSelector -- ScrollingFrame
	local TextButtonTFSS = SoundSelector.TextButton -- TextButton (Template)

	local Play = Parent.Play -- TextButton
	local Loop = Parent.LOOP -- TextButton

	local DelayBetweenPlayerTB = Parent.DelayBetweenPlayer -- TextBox
	local SoundDurationDragger = Parent.SoundDurationDragger -- Frame
	local SoundDurationDraggerSlider = SoundDurationDragger.DragLEFTANDRIGHTONLY -- TextButton

	local PlayerOnly = Parent.PlayerOnly -- TextButton
	local ScrollingFramePO = PlayerOnly.ScrollingFrame -- ScrollingFrame
	local SFPOTemplate = ScrollingFramePO.Template_Button -- TextButton

	local SelectedSoundData = nil -- Guardará {Name = string, SoundId = string, TimeLength = number}
	local LoopActive = false
	local LoopThreads = {} -- Para poder cancelar las corutinas si se frena el loop

	-- Nueva variable para rastrear el objetivo seleccionado (puede ser "ALL" o un objeto Player)
	local TargetPlayer = "ALL" 

	-- Variables de configuración por defecto
	local CurrentDurationFactor = 1 -- Va de 0 a 1 (posición del slider)

	local GetPlayerHead = function(Player: Player)
		local Character = Player.Character
		if not Character then return end

		-- Mantenida tu lógica personalizada de Studio vs juego real
		local Head = game:GetService("RunService"):IsStudio() and Character:FindFirstChild("HumanoidRootPart") or Character:FindFirstChild("Head")
		if not Head then return end

		return Head
	end

	local function GetSoundsInBasePart(BasePart: BasePart)
		local List = {};
		for _, Sound in BasePart:GetChildren() do
			if Sound:IsA("Sound") then
				table.insert(List, Sound)
			end
		end
		return List
	end;

	repeat print"waiting for sounds" wait(1) until #GetSoundsInBasePart(GetPlayerHead(game.Players.LocalPlayer)) > 0

	function clear_children(sf:ScrollingFrame) 
		for _, v in sf:GetChildren() do 
			if v:IsA("TextButton") then v:Destroy() end 
		end 
	end

	local LocalPlayer = game:GetService("Players").LocalPlayer
	local TemplateOrigin = TextButtonTFSS:Clone()
	TextButtonTFSS.Visible = false

	local POTemplateOrigin = SFPOTemplate:Clone()
	SFPOTemplate.Visible = false

	-- Actualizar el texto del botón principal (Main)
	local function UpdateMainText()
		if SelectedSoundData then
			local idStr = tostring(SelectedSoundData.SoundId):match("%d+$") or "???"
			local lastThree = idStr:sub(-3)
			Main.Text = string.format("< Selected Sound >\n%s (@%s)\n(LMC4 Selecting)", SelectedSoundData.Name, lastThree)
		else
			Main.Text = "< Selected Sound >\nCore (No Sound Loaded)\n(LMC4 Selecting)"
		end
	end

	-- Lógica del Slider (Drag)
	local UserInputService = game:GetService("UserInputService")
	local dragging = false

	SoundDurationDraggerSlider.MouseButton1Down:Connect(function()
		dragging = true
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local frameAbsPos = SoundDurationDragger.AbsolutePosition.X
			local frameAbsSize = SoundDurationDragger.AbsoluteSize.X
			local mouseX = input.Position.X

			-- Clampear la posición dentro de los límites del Frame contenedor
			local relativeX = math.clamp(mouseX - frameAbsPos, 0, frameAbsSize)
			CurrentDurationFactor = relativeX / frameAbsSize

			-- Actualizar posición visual del slider
			SoundDurationDraggerSlider.Position = UDim2.new(0, relativeX - (SoundDurationDraggerSlider.AbsoluteSize.X / 2), SoundDurationDraggerSlider.Position.Y.Scale, SoundDurationDraggerSlider.Position.Y.Offset)
			-- Mostrar porcentaje o factor redondeado en el texto del dragger
			SoundDurationDraggerSlider.Text = tostring(math.round(CurrentDurationFactor * 100))
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	-- Resetear Slider a su valor máximo (Predeterminado: 100%)
	local function ResetSlider()
		CurrentDurationFactor = 1
		local frameAbsSize = SoundDurationDragger.AbsoluteSize.X
		SoundDurationDraggerSlider.Position = UDim2.new(0, frameAbsSize - (SoundDurationDraggerSlider.AbsoluteSize.X / 2), SoundDurationDraggerSlider.Position.Y.Scale, SoundDurationDraggerSlider.Position.Y.Offset)
		SoundDurationDraggerSlider.Text = "100"
	end

	-- Togglear visibilidad del SoundSelector al presionar Main
	Main.MouseButton1Click:Connect(function()
		SoundSelector.Visible = not SoundSelector.Visible
	end)

	-- Togglear visibilidad del ScrollingFrame de PlayerOnly
	PlayerOnly.MouseButton1Click:Connect(function()
		ScrollingFramePO.Visible = not ScrollingFramePO.Visible
	end)

	-- Reproducir preview rápido usando PlayOnRemove
	local function PlayPreview(soundId)
		local preview = Instance.new("Sound")
		preview.SoundId = soundId
		preview.Volume = 0.5
		preview.PlayOnRemove = true
		preview.Parent = game:GetService("SoundService")
		preview:Destroy()
	end

	-- Poblar la lista de sonidos desde la cabeza del LocalPlayer
	local function UpdateSoundPack()
		clear_children(SoundSelector)
		local head = GetPlayerHead(LocalPlayer)
		if not head then return end

		local currentSounds = GetSoundsInBasePart(head);

		for _, sound in currentSounds do
			local Template = TemplateOrigin:Clone()
			Template.Text = sound.Name
			Template.Name = sound.Name
			Template.Visible = true
			Template.Parent = SoundSelector
			Template.Transparency = 0
			Template.BorderSizePixel = 1

			Template.MouseButton1Click:Connect(function()
				SelectedSoundData = {
					Name = sound.Name,
					SoundId = sound.SoundId,
					TimeLength = sound.TimeLength > 0 and sound.TimeLength or 5
				}
				UpdateMainText()
				ResetSlider()
				PlayPreview(sound.SoundId)
				SoundSelector.Visible = false
			end)
		end
	end

	-- Lógica de Gestión de la lista PlayerOnly
	local function RefreshPlayerOnlyList()
		-- Limpiamos únicamente los botones generados dinámicamente
		for _, child in ScrollingFramePO:GetChildren() do
			if child:IsA("TextButton") then
				child:Destroy()
			end
		end

		-- 1. Crear el botón maestro "TODOS"
		local AllTemplate = POTemplateOrigin:Clone()
		AllTemplate.Text = "TODOS"
		AllTemplate.Name = "ALL_TARGET"
		AllTemplate.Visible = true
		AllTemplate.Parent = ScrollingFramePO

		if TargetPlayer == "ALL" then
			PlayerOnly.Text = "Target: EVERYONE"
		end

		AllTemplate.MouseButton1Click:Connect(function()
			TargetPlayer = "ALL"
			PlayerOnly.Text = "Target: EVERYONE"
			ScrollingFramePO.Visible = false
		end)

		-- 2. Crear un botón por cada jugador en el servidor
		for _, player in game:GetService("Players"):GetPlayers() do
			local PlayerTemplate = POTemplateOrigin:Clone()
			PlayerTemplate.Text = player.DisplayName or player.Name
			PlayerTemplate.Name = player.Name
			PlayerTemplate.Visible = true
			PlayerTemplate.Parent = ScrollingFramePO

			-- Si por alguna razón el jugador actual coincide con el TargetPlayer guardado
			if TargetPlayer == player then
				PlayerOnly.Text = "Target: " .. player.Name
			end

			PlayerTemplate.MouseButton1Click:Connect(function()
				TargetPlayer = player
				PlayerOnly.Text = "Target: " .. player.Name
				ScrollingFramePO.Visible = false
			end)
		end
	end

	-- Escuchar conexiones y desconexiones para actualizar el listado de jugadores
	game:GetService("Players").PlayerAdded:Connect(function()
		RefreshPlayerOnlyList()
	end)

	game:GetService("Players").PlayerRemoving:Connect(function(player)
		-- Si el jugador que se va era nuestro target, volvemos a "ALL" por defecto
		if TargetPlayer == player then
			TargetPlayer = "ALL"
			PlayerOnly.Text = "Target: EVERYONE"
		end
		RefreshPlayerOnlyList()
	end)

	-- Control individual de reproducción por Head (Soporta truncado y loops internos rápidos)
	local function PlaySoundOnHead(head, soundData, duration)
		local targetSound = head:FindFirstChild(soundData.Name)
		if not targetSound or not targetSound:IsA("Sound") then return end

		local thread = task.spawn(function()
			while true do
				targetSound:Play()
				task.wait(duration)
				targetSound:Stop()

				if not LoopActive then break end
			end
		end)

		if LoopActive then
			table.insert(LoopThreads, thread)
		end
	end

	-- Ejecución principal del Player
	local function ExecuteSoundPlayback()
		if not SelectedSoundData then return end

		local delayTime = tonumber(DelayBetweenPlayerTB.Text) or 0
		local calculatedDuration = SelectedSoundData.TimeLength * CurrentDurationFactor

		if delayTime < 0 then delayTime = 0 end 

		-- Filtrar la lista de objetivos basados en la selección de PlayerOnly
		local targets = {}
		if TargetPlayer == "ALL" then
			targets = game:GetService("Players"):GetPlayers()
		else
			-- Validar que el jugador objetivo siga existiendo en el juego
			if TargetPlayer and TargetPlayer.Parent == game:GetService("Players") then
				table.insert(targets, TargetPlayer)
			end
		end

		if delayTime == 0 then
			-- Modo Instantáneo
			for _, player in targets do
				local head = GetPlayerHead(player)
				if head then
					task.spawn(PlaySoundOnHead, head, SelectedSoundData, calculatedDuration)
				end
			end
		else
			-- Modo Secuencial con retraso
			task.spawn(function()
				for _, player in targets do
					local head = GetPlayerHead(player)
					if head then
						task.spawn(PlaySoundOnHead, head, SelectedSoundData, calculatedDuration)
						task.wait(delayTime)
					end
				end
			end)
		end
	end

	-- Conexión de Botón Play
	Play.MouseButton1Click:Connect(function()
		LoopActive = false 
		Loop.Text = "LOOP"
		for _, th in LoopThreads do
			pcall(task.cancel, th)
		end
		table.clear(LoopThreads)

		ExecuteSoundPlayback()
	end)

	-- Conexión de Botón Loop
	Loop.MouseButton1Click:Connect(function()
		if not LoopActive then
			LoopActive = true
			Loop.Text = "Stop"
			ExecuteSoundPlayback()
		else
			LoopActive = false
			Loop.Text = "LOOP"
			for _, th in LoopThreads do
				pcall(task.cancel, th)
			end
			table.clear(LoopThreads)
		end
	end)

	-- Inicialización
	UpdateSoundPack()
	UpdateMainText()
	RefreshPlayerOnlyList()
	ScrollingFramePO.Visible = false
	task.defer(ResetSlider)
end;
task.spawn(C_12b);
-- StarterGui.WAAPP_Gui.WindowFrame.ContentArea.misc3.MyButton.LocalScript
local function C_13a()
	local script = G2L["13a"];

	local function getTeamSpawnCFrame(teamName)
		local team = game.Teams:FindFirstChild(teamName)
		if team == nil then
			return nil
		end

		for _, instance in ipairs(workspace:GetChildren()) do
			if instance:IsA("SpawnLocation") and instance.TeamColor == team.TeamColor then
				return instance.CFrame
			end
		end

		return nil
	end


	local Names = {'Cashier',
		'Cook',
		'Pizza Boxer',
		'Delivery',
		'Supplier',
		'Manager',
	}

	local teleportPlaces = {
		["Cashier Area"] = getTeamSpawnCFrame(Names[1]),
		["Cook Area"] = getTeamSpawnCFrame(Names[2]),
		["Boxer Area"] = getTeamSpawnCFrame(Names[3]),
		["Delivery Area"] = getTeamSpawnCFrame(Names[4]),
		["Supplier Area"] = getTeamSpawnCFrame(Names[5]),
		["Manager Room"] = getTeamSpawnCFrame(Names[6])
	}

	-- 🏎️ Función para encontrar y sentarse en vehículo
	local function trySitInVehicle(humanoid: Humanoid?, folder: Folder, character: Model, oldpos: CFrame)
		if not humanoid or humanoid.Health <= 0 then return end
		local root = character:FindFirstChild("HumanoidRootPart")
		local oldPos = oldpos or (root and root.CFrame)

		-- Si ya está en un vehículo de esa carpeta, no hace nada
		if humanoid.SeatPart and folder:IsAncestorOf(humanoid.SeatPart) then
			return
		end

		humanoid.Sit = false
		task.wait(0.1)

		-- Buscar un vehículo libre
		for _, vehicle in ipairs(folder:GetChildren()) do
			if vehicle:FindFirstChild("Driver") and vehicle.Driver.Occupant == nil then
				if vehicle:FindFirstChild("Owner") and vehicle.Owner.Value ~= nil then
					continue
				end
				vehicle.Driver:Sit(humanoid)
				task.wait(0.3)
				if humanoid.SeatPart then
					break
				end
			end
		end

		-- Teleportar el vehículo a la posición original del player
		if humanoid.SeatPart and oldPos then
			local car = humanoid.SeatPart.Parent
			if car.PrimaryPart then
				car:SetPrimaryPartCFrame(oldPos)
			else
				-- fallback: usar Driver como PrimaryPart temporal
				local driver = car:FindFirstChild("Driver")
				if driver then
					car.PrimaryPart = driver
					car:SetPrimaryPartCFrame(oldPos)
				end
			end
		end
	end


	local player = game.Players.LocalPlayer

	-- Variable global para no spawnear mil veces el BodyAngularVelocity
	local currentSpinForce = nil  

	-- Función para hacer spin al auto
	local function SpinCar(carModel: Model, spinSpeed: number)
		if not carModel or not carModel.PrimaryPart then
			warn("❌ El auto no tiene PrimaryPart asignado")
			return
		end

		local seat = carModel:FindFirstChildWhichIsA("VehicleSeat", true)
		if not seat then
			warn("❌ El auto no tiene VehicleSeat")
			return
		end

		-- Verificar que el jugador esté sentado en el auto
		if seat.Occupant ~= player.Character:FindFirstChild("Humanoid") then
			warn("⚠️ No estás sentado en este auto")
			return
		end

		-- Si ya existe un spin activo, lo quitamos primero
		if currentSpinForce then
			currentSpinForce:Destroy()
			currentSpinForce = nil
		end

		-- Crear BodyAngularVelocity para girar el auto
		local bav = Instance.new("BodyAngularVelocity")
		bav.AngularVelocity = Vector3.new(0, spinSpeed, 0) -- spin en Y
		bav.MaxTorque = Vector3.new(0, math.huge, 0) -- torque infinito en Y
		bav.P = 10000
		bav.Parent = carModel.PrimaryPart

		currentSpinForce = bav
	end

	local function getcar()
		local character = game.Players.LocalPlayer.Character
		if not character then
			return nil
		end

		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if not humanoid then
			return nil
		end

		local seat = humanoid.SeatPart
		if seat and (seat:IsA("VehicleSeat") or seat:IsA("Seat")) then
			return seat.Parent
		end

		return nil
	end


	script.Parent.Activated:Connect(function()
		local player = game.Players.LocalPlayer
		local character = player.Character
		if not character then return end
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if not humanoid or humanoid.Health <= 0 then return end

		trySitInVehicle(humanoid, game.Workspace.Vehicles, character, teleportPlaces["Cook Area"]);
		local fallbacktime = false;

		local delayThread = task.delay(3, function()
			if not fallbacktime then
				fallbacktime = true;
			end
		end)

		repeat
			task.wait()
		until humanoid.SeatPart or fallbacktime

		if delayThread then
			task.cancel(delayThread)
		end

		local car = getcar()

		if car then
			SpinCar(car, 20);
		end

	end)
end;
