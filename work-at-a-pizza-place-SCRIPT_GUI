local function C_cf()
	local script = G2L["cf"];
	-- 📦 Car/Truck Handler mejorado con soporte para respawn
	local textBox = script.Parent

	-- Función para actualizar el texto
	local function setLabel(name: string)
		if typeof(name) == "string" then
			textBox.Text = name
		end
	end

	-- ObjectValue para guardar el auto actual
	local CarObjectValue = Instance.new("ObjectValue")
	CarObjectValue.Name = "CarObjectValue"
	CarObjectValue.Parent = textBox

	-- Jugador local
	local LocalPlayer = game:GetService("Players").LocalPlayer

	-- 🔄 Función para actualizar el auto actual
	local function updateCurrentCar(humanoid: Humanoid?)
		if not humanoid or humanoid.Health <= 0 then
			CarObjectValue.Value = nil
			setLabel("")
			return
		end

		local seat = humanoid.SeatPart
		if seat and (seat:IsA("VehicleSeat") or seat:IsA("Seat")) then
			local car = seat.Parent
			CarObjectValue.Value = car
			setLabel("Actual Car - " .. car.Name)
		else
			CarObjectValue.Value = nil
			setLabel("")
		end
	end

	-- 🏎️ Función para encontrar y sentarse en vehículo
	local function trySitInVehicle(humanoid: Humanoid?, folder: Folder, character: Model)
		if not humanoid or humanoid.Health <= 0 then return end
		local root = character:FindFirstChild("HumanoidRootPart")
		local oldPos = root and root.CFrame

		-- Si ya está en un vehículo de esa carpeta, no hace nada
		if humanoid.SeatPart and folder:IsAncestorOf(humanoid.SeatPart) then
			return
		end

		humanoid.Sit = false
		task.wait(0.1)

		-- Buscar un vehículo libre
		for _, vehicle in ipairs(folder:GetChildren()) do
			if vehicle:FindFirstChild("Driver") and vehicle.Driver.Occupant == nil then
				if vehicle:FindFirstChild("Owner") and vehicle.Owner.Value ~= nil then
					continue
				end
				vehicle.Driver:Sit(humanoid)
				task.wait(0.3)
				if humanoid.SeatPart then
					break
				end
			end
		end

		-- Teleportar el vehículo a la posición original del player
		if humanoid.SeatPart and oldPos then
			local car = humanoid.SeatPart.Parent
			if car.PrimaryPart then
				car:SetPrimaryPartCFrame(oldPos)
			else
				-- fallback: usar Driver como PrimaryPart temporal
				local driver = car:FindFirstChild("Driver")
				if driver then
					car.PrimaryPart = driver
					car:SetPrimaryPartCFrame(oldPos)
				end
			end
		end
	end

	-- 📌 Conectar todo al humanoide válido
	local function connectHumanoid(humanoid: Humanoid, character: Model)
		-- actualizar al inicio
		updateCurrentCar(humanoid)

		-- escuchar cambios de SeatPart
		humanoid:GetPropertyChangedSignal("SeatPart"):Connect(function()
			updateCurrentCar(humanoid)
		end)

		-- manejar comandos en TextBox
		textBox.FocusLost:Connect(function()
			local command = textBox.Text:lower()

			if command == "car" or command == "vehicle" then
				trySitInVehicle(humanoid, workspace.Cars, character)
			elseif command == "truck" or command == "bigcar" then
				trySitInVehicle(humanoid, workspace.Trucks, character)
			end

			updateCurrentCar(humanoid)
		end)
	end

	-- 🔄 Reconectar en cada respawn
	local function onCharacterAdded(character: Model)
		local humanoid: Humanoid = character:WaitForChild("Humanoid")
		connectHumanoid(humanoid, character)
	end

	LocalPlayer.CharacterAdded:Connect(onCharacterAdded)
	if LocalPlayer.Character then
		onCharacterAdded(LocalPlayer.Character)
	end

end;
