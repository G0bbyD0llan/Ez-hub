-- StarterGui.WAAPP_Gui.WindowFrame.CloseWarning.Frame.yes.LocalScript
local function C_146()
	local script = G2L["146"];
	local TweenService = game:GetService("TweenService")
	local yesButton = script.Parent
	local screenGui = yesButton.Parent.Parent.Parent.Parent
	local windowFrame = screenGui:FindFirstChild("WindowFrame")

	-- Función para crear un Tween
	local function createTween(object, properties, duration)
		local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		local tween = TweenService:Create(object, tweenInfo, properties)
		tween:Play()
		return tween
	end

	-- Función para ocultar con Tween
	local function fadeOut(object, duration)
		if object:IsA("GuiObject") then
			createTween(object, {Transparency = 1}, duration)
		end

		-- Si es un ImageLabel o ImageButton, también ajustamos la transparencia de la imagen
		if object:IsA("ImageLabel") or object:IsA("ImageButton") then
			createTween(object, {ImageTransparency = 1}, duration)
		end

		-- Aplicamos a los hijos
		for _, child in ipairs(object:GetChildren()) do
			fadeOut(child, duration)
		end
	end

	-- Evento de clic en el botón "Yes"
	yesButton.MouseButton1Click:Connect(function()
		-- Oculta los botones de confirmación
		yesButton.Visible = false
		if yesButton.Parent:FindFirstChild("no") then
			yesButton.Parent.no.Visible = false
		end

		-- Cambiar el título de la ventana
		yesButton.Parent.Parent.title.Text = "Ok, Closing..."
		-- Mensaje de despedida
		yesButton.Parent.Parent.warning.Text = "Thanks for using my script"

		wait(1)

		-- Desvanecer toda la ventana
		if windowFrame then
			fadeOut(windowFrame, 2)
		end
		-- Esperar el tiempo del tween antes de destruir
		task.wait(2)

		-- Eliminar la GUI completamente
		screenGui:Destroy()

	end)

end;
task.spawn(C_146);

