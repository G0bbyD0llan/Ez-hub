		if not CarObjectValue or not CarObjectValue.Value then
			return nil
		end

		return CarObjectValue.Value
	end

	-- 📌 Smooth Teleport con spin y disable collisions
	local function SmoothTPToCFrame(Car: Model, targetCFrame: CFrame, duration: number)
		duration = duration or 1
		local startTime = tick()

		local startCFrame = Car:GetPivot()
		local parts = Car:GetDescendants()
		local collides = {}

		for _, p in ipairs(parts) do
			if p:IsA("BasePart") then
				collides[p] = p.CanCollide
				p.CanCollide = false
			end
		end

		local connection
		connection = game:GetService("RunService").Heartbeat:Connect(function()
			local elapsed = tick() - startTime
			local alpha = math.clamp(elapsed / duration, 0, 1)

			local newCFrame = startCFrame:Lerp(targetCFrame, alpha)
			local spin = CFrame.Angles(0, math.rad(720 * alpha), 0)
			Car:PivotTo(newCFrame * spin)

			if alpha >= 1 then
				connection:Disconnect()
				for part, oldCollide in pairs(collides) do
					if part and part.Parent then
						part.CanCollide = oldCollide
					end
				end
			end
		end)
	end

